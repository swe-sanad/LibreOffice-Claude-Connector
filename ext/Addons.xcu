<?xml version="1.0" encoding="UTF-8"?>
<oor:component-data xmlns:oor="http://openoffice.org/2001/registry"
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    oor:name="Addons" oor:package="org.openoffice.Office">
  <node oor:name="AddonUI">

    <!-- Tools > Add-Ons submenu entries (the standard add-on location) -->
    <node oor:name="AddonMenu">
      <node oor:name="com.swepioneers.claudeconnector.addon.transform" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>com.swepioneers.claudeconnector:Transform</value>
        </prop>
        <prop oor:name="Title" oor:type="xs:string">
          <value xml:lang="en-US">Transform Selection with Claude…</value>
        </prop>
        <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
        <prop oor:name="Context" oor:type="xs:string">
          <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.TextDocument</value>
        </prop>
      </node>
      <node oor:name="com.swepioneers.claudeconnector.addon.settings" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>com.swepioneers.claudeconnector:Settings</value>
        </prop>
        <prop oor:name="Title" oor:type="xs:string">
          <value xml:lang="en-US">Claude Settings…</value>
        </prop>
        <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
        <prop oor:name="Context" oor:type="xs:string">
          <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.TextDocument</value>
        </prop>
      </node>
    </node>

    <!-- Top-level "Claude" menu, shown only in Calc and Writer -->
    <node oor:name="OfficeMenuBar">
      <node oor:name="com.swepioneers.claudeconnector" oor:op="replace">
        <prop oor:name="Title" oor:type="xs:string">
          <value xml:lang="en-US">Claude</value>
        </prop>
        <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
        <prop oor:name="Context" oor:type="xs:string">
          <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.TextDocument</value>
        </prop>
        <node oor:name="Submenu">
          <node oor:name="m1" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>com.swepioneers.claudeconnector:Transform</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Transform Selection with Claude…</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.TextDocument</value>
            </prop>
          </node>
          <node oor:name="mSummarize" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>com.swepioneers.claudeconnector:Summarize</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Summarize Selection</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.TextDocument</value>
            </prop>
          </node>
          <node oor:name="mTranslate" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>com.swepioneers.claudeconnector:Translate</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Translate Selection…</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.TextDocument</value>
            </prop>
          </node>
          <node oor:name="mFixGrammar" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>com.swepioneers.claudeconnector:FixGrammar</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Fix Grammar &amp; Spelling</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.TextDocument</value>
            </prop>
          </node>
          <node oor:name="mGenFormula" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>com.swepioneers.claudeconnector:GenerateFormula</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Generate Formula… (Calc)</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.sheet.SpreadsheetDocument</value>
            </prop>
          </node>
          <node oor:name="mExplainRange" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>com.swepioneers.claudeconnector:ExplainRange</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Explain Range (Calc)</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.sheet.SpreadsheetDocument</value>
            </prop>
          </node>
          <node oor:name="m2" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>private:separator</value>
            </prop>
          </node>
          <node oor:name="m3" oor:op="replace">
            <prop oor:name="URL" oor:type="xs:string">
              <value>com.swepioneers.claudeconnector:Settings</value>
            </prop>
            <prop oor:name="Title" oor:type="xs:string">
              <value xml:lang="en-US">Settings…</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
          </node>
        </node>
      </node>
    </node>

    <!-- Toolbar button -->
    <node oor:name="OfficeToolBar">
      <node oor:name="com.swepioneers.claudeconnector.toolbar" oor:op="replace">
        <node oor:name="t1" oor:op="replace">
          <prop oor:name="URL" oor:type="xs:string">
            <value>com.swepioneers.claudeconnector:Transform</value>
          </prop>
          <prop oor:name="Title" oor:type="xs:string">
            <value xml:lang="en-US">Transform with Claude</value>
          </prop>
          <prop oor:name="Target" oor:type="xs:string"><value>_self</value></prop>
          <prop oor:name="Context" oor:type="xs:string">
            <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.TextDocument</value>
          </prop>
        </node>
      </node>
    </node>

    <!-- Icons for the Transform command -->
    <node oor:name="Images">
      <node oor:name="com.swepioneers.claudeconnector.image" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>com.swepioneers.claudeconnector:Transform</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmallURL">
            <value>%origin%/icons/cmd16.png</value>
          </prop>
          <prop oor:name="ImageBigURL">
            <value>%origin%/icons/cmd26.png</value>
          </prop>
        </node>
      </node>
    </node>

  </node>
</oor:component-data>
